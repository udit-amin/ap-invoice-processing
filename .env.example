# Copy to .env and fill in. .env is git-ignored; never commit real secrets.

# --- Anthropic ---------------------------------------------------------------
# API key for Claude extraction. Without it, live extraction is skipped and the
# harness/tests fall back to the answer key.
ANTHROPIC_API_KEY=sk-ant-...

# --- Database ----------------------------------------------------------------
# Postgres DSN. Defaults to the docker-compose service when unset.
DATABASE_URL=postgresql://ap:ap@localhost:5432/ap_invoices

# --- Auth / JWT --------------------------------------------------------------
# HS256 signing secret. REQUIRED in production (the app refuses to start signing
# tokens with the insecure dev fallback when ENVIRONMENT=production).
JWT_SECRET=change-me-to-a-long-random-string
# Access-token lifetime in seconds (default 3600 = 1 hour).
JWT_EXPIRE_SECONDS=3600

# --- Deployment --------------------------------------------------------------
# production | development. development enables the dev JWT fallback; the
# container/AWS task sets this to production.
ENVIRONMENT=development

# Set true ONLY on demo deployments to expose the manager-only, destructive
# POST /admin/reset-demo (the in-app "Reset demo data" button). Leave unset in a
# real production environment so processed data can't be wiped by a click.
ALLOW_DEMO_RESET=false

# --- UI (v4) -----------------------------------------------------------------
# Backend base URL the Streamlit UI (ui/app.py) calls. Defaults to the local API
# when unset; point it at the AWS ALB URL to run the same UI against production.
API_BASE_URL=http://localhost:8000
