# Secrets — never commit
.env

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# macOS
.DS_Store

# Editor / tooling
.claude/

# Generated data (PDFs are regenerated from app/generate/ + scripts/)
data/inputs/*.pdf
data/demo_live/*.pdf

# Ingest worker landing/archive (runtime PDFs; landing dir kept via .gitkeep)
data/landing/*.pdf
data/archive/

# Stray SQLite artifacts — the pipeline uses Postgres; *.db should never be committed
*.db
